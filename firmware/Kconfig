mainmenu "The-Tag Firmware Configuration"

config FIND_MY
	bool "Apple Find My (OpenHaystack) support"
	default y
	depends on BT && BT_BROADCASTER && BT_EXT_ADV
	help
	  Enables non-connectable BLE advertising compatible with Apple's
	  Find My network using the OpenHaystack Offline Finding protocol.
	  When enabled, the device broadcasts a manufacturer-specific
	  advertisement that nearby Apple devices silently relay to Apple's
	  servers, allowing the tag to appear in the Find My app.

	  A unique EC P-224 key pair must be generated with the OpenHaystack
	  desktop application for production use.  See firmware/src/find_my.h
	  for details on key provisioning and rotation.

	  Reference: https://github.com/seemoo-lab/openhaystack

if FIND_MY

config FIND_MY_DEMO_KEY
	bool "Use built-in demonstration public key"
	default y
	help
	  Use the placeholder public key hard-coded in find_my.c.  This is
	  intended only for verifying the advertisement format during
	  development.  The placeholder key is NOT a valid EC P-224 point and
	  will NOT decrypt correctly on Apple's servers.

	  Disable this option and provision a real key pair generated by the
	  OpenHaystack desktop application before shipping.

endif # FIND_MY

source "Kconfig.zephyr"
